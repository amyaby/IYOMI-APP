<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <!-- 1. SPLASH -->
    <fragment
        android:id="@+id/splashFragment"
        android:name="com.yomi.ui.fragments.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_splash_to_register"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- 2. LOGIN -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.yomi.ui.fragments.LoginFragment"
        android:label="Connexion"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
    </fragment>

    <!-- 3. REGISTER -->
    <fragment
        android:id="@+id/registerFragment"
        android:name="com.yomi.ui.fragments.RegisterFragment"
        android:label="Inscription"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_register_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment" />
    </fragment>

    <!-- 4. HOME DASHBOARD -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.yomi.ui.fragments.HomeFragment"
        android:label="Tableau de bord"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_create"
            app:destination="@id/createStoryFragment" />
        <action
            android:id="@+id/action_home_to_draw"
            app:destination="@id/drawFragment" />
        <action
            android:id="@+id/action_home_to_reveal"
            app:destination="@id/revealFragment" />
        <action
            android:id="@+id/action_home_to_myBds"
            app:destination="@id/myBdsFragment" />
        <action
            android:id="@+id/action_home_to_explore"
            app:destination="@id/explorerFragment" />
        <action
            android:id="@+id/action_home_to_profile"
            app:destination="@id/profileFragment" />
        <action
            android:id="@+id/action_home_to_friends"
            app:destination="@id/friendsFragment" />
    </fragment>

    <!-- 5. CREATE STORY -->
    <fragment
        android:id="@+id/createStoryFragment"
        android:name="com.yomi.ui.fragments.CreateStoryFragment"
        android:label="Créer une histoire"
        tools:layout="@layout/fragment_create_story">
        <argument
            android:name="initialPlayerId"
            app:argType="long"
            android:defaultValue="-1L" />
        <action
            android:id="@+id/action_create_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- 6. DRAW CANVAS -->
    <fragment
        android:id="@+id/drawFragment"
        android:name="com.yomi.ui.fragments.DrawFragment"
        android:label="Dessiner"
        tools:layout="@layout/fragment_draw">
        <argument
            android:name="storyId"
            app:argType="long" />
        <action
            android:id="@+id/action_draw_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- 7. MY BDS -->
    <fragment
        android:id="@+id/myBdsFragment"
        android:name="com.yomi.ui.fragments.MyBdsFragment"
        android:label="Mes BDs"
        tools:layout="@layout/fragment_my_bds">
        <action
            android:id="@+id/action_myBds_to_reveal"
            app:destination="@id/revealFragment" />
        <action
            android:id="@+id/action_myBds_to_draw"
            app:destination="@id/drawFragment" />
    </fragment>

    <!-- 8. EXPLORER -->
    <fragment
        android:id="@+id/explorerFragment"
        android:name="com.yomi.ui.fragments.ExplorerFragment"
        android:label="Explorer"
        tools:layout="@layout/fragment_explorer">
        <action
            android:id="@+id/action_explorer_to_reveal"
            app:destination="@id/revealFragment" />
        <action
            android:id="@+id/action_explorer_to_draw"
            app:destination="@id/drawFragment" />
    </fragment>

    <!-- 9. PROFILE -->
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.yomi.ui.fragments.ProfileFragment"
        android:label="Profil"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_profile_to_splash"
            app:destination="@id/splashFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_profile_to_edit"
            app:destination="@id/editProfileFragment" />
        <action
            android:id="@+id/action_profile_to_notifications"
            app:destination="@id/notificationsFragment" />
        <action
            android:id="@+id/action_profile_to_privacy"
            app:destination="@id/privacyFragment" />
    </fragment>

    <!-- 10. FINAL REVEAL -->
    <fragment
        android:id="@+id/revealFragment"
        android:name="com.yomi.ui.fragments.RevealFragment"
        android:label="Révélation"
        tools:layout="@layout/fragment_reveal">
        <argument
            android:name="storyId"
            app:argType="long" />
        <action
            android:id="@+id/action_reveal_to_myBds"
            app:destination="@id/myBdsFragment" />
    </fragment>

    <!-- 11. EDIT PROFILE -->
    <fragment
        android:id="@+id/editProfileFragment"
        android:name="com.yomi.ui.fragments.EditProfileFragment"
        android:label="Modifier le profil"
        tools:layout="@layout/fragment_edit_profile" />

    <!-- 12. NOTIFICATIONS -->
    <fragment
        android:id="@+id/notificationsFragment"
        android:name="com.yomi.ui.fragments.NotificationsFragment"
        android:label="Notifications"
        tools:layout="@layout/fragment_notifications" />

    <!-- 13. PRIVACY -->
    <fragment
        android:id="@+id/privacyFragment"
        android:name="com.yomi.ui.fragments.PrivacyFragment"
        android:label="Confidentialité"
        tools:layout="@layout/fragment_privacy" />

    <!-- 14. FRIENDS -->
    <fragment
        android:id="@+id/friendsFragment"
        android:name="com.yomi.ui.fragments.FriendsFragment"
        android:label="Amis"
        tools:layout="@layout/fragment_friends">
        <action
            android:id="@+id/action_friends_to_profile"
            app:destination="@id/profileFragment" />
    </fragment>

</navigation>
