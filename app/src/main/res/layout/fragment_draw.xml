<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/draw_hdr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:paddingTop="36dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill_pink"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp">

            <ImageView
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:src="@drawable/ic_clock"
                app:tint="@color/pill_p_text" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:fontFamily="sans-serif-bold"
                android:text="13h 42m"
                android:textColor="@color/pill_p_text"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPanelIndex"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Panel 3 / 4"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/btnTogglePrevious"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill_purple"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_eye"
                app:tint="@color/pill_v_text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="Panel préc."
                android:textColor="@color/pill_v_text"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Canvas Area Container -->
    <FrameLayout
        android:id="@+id/canvas_container"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_marginHorizontal="14dp"
        android:background="@color/white"
        app:layout_constraintTop_toBottomOf="@id/draw_hdr">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Previous Panel Preview Area -->
            <FrameLayout
                android:id="@+id/previous_panel_preview"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="#F0EDF7"
                android:visibility="visible">

                <ImageView
                    android:id="@+id/ivPreviousPanel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:text="Panel précédent"
                    android:textColor="@color/text_muted"
                    android:textSize="9sp" />

                <TextView
                    android:id="@+id/tvPreviousBubble"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_edittext"
                    android:backgroundTint="@color/white"
                    android:paddingHorizontal="7dp"
                    android:paddingVertical="2dp"
                    android:text="Hein ?!"
                    android:textColor="@color/text_main"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- Actual Drawing Canvas Container -->
            <FrameLayout
                android:id="@+id/current_drawing_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <com.yomi.ui.fragments.YomiCanvasView
                    android:id="@+id/canvasView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <!-- New bubbles will be added here dynamically -->
                <TextView
                    android:id="@+id/tvPlacedBubble"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="10dp"
                    android:background="@drawable/bg_edittext"
                    android:backgroundTint="@color/white"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:textColor="@color/text_main"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </FrameLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- Tools Bar -->
    <LinearLayout
        android:id="@+id/tools_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toBottomOf="@id/canvas_container">

        <ImageButton
            android:id="@+id/btnPencil"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_nav_btn"
            android:backgroundTint="@color/pill_v_bg"
            android:src="@drawable/ic_pencil"
            app:tint="@color/pill_v_text" />

        <ImageButton
            android:id="@+id/btnEraser"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="7dp"
            android:background="@drawable/bg_nav_btn"
            android:src="@drawable/ic_eraser"
            app:tint="@color/text_muted" />

        <ImageButton
            android:id="@+id/btnUndo"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="7dp"
            android:background="@drawable/bg_nav_btn"
            android:src="@drawable/ic_undo"
            app:tint="@color/text_muted" />

        <ImageButton
            android:id="@+id/btnRedo"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="7dp"
            android:background="@drawable/bg_nav_btn"
            android:src="@drawable/ic_redo"
            app:tint="@color/text_muted" />

        <ImageButton
            android:id="@+id/btnTrash"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="7dp"
            android:background="@drawable/bg_nav_btn"
            android:src="@drawable/ic_trash"
            app:tint="@color/text_muted" />

        <SeekBar
            android:id="@+id/sbStroke"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="50"
            android:progress="8" />
    </LinearLayout>

    <!-- Colors Row -->
    <HorizontalScrollView
        android:id="@+id/colors_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="14dp"
        android:paddingBottom="8dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/tools_bar">

        <LinearLayout
            android:id="@+id/colors_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <!-- Colors dots will be added here -->
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Bubble Tool Panel -->
    <LinearLayout
        android:id="@+id/bubble_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="14dp"
        android:background="@drawable/bg_edittext"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/colors_scroll"
        app:layout_constraintVertical_bias="0">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="sans-serif-bold"
            android:text="Bulle de dialogue"
            android:textColor="@color/primary"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etBubbleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_edittext"
                android:backgroundTint="@color/white"
                android:hint="Texte de la bulle…"
                android:padding="7dp"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnPlace"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginStart="7dp"
                android:backgroundTint="@color/pill_v_bg"
                android:minWidth="0dp"
                android:text="Placer"
                android:textAllCaps="false"
                android:textColor="@color/pill_v_text"
                android:textSize="11sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnSubmit"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginStart="7dp"
                android:backgroundTint="@color/primary"
                android:minWidth="0dp"
                android:text="Soumettre"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
