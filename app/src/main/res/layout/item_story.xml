<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="160dp"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvStoryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="L'Alien au café"
            android:textColor="@color/text_main"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStoryMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4 panels · 3/4 joueurs"
            android:textColor="@color/text_muted"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/tvStatusPill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_pill_pink"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:text="Ton tour"
            android:textColor="@color/pill_p_text"
            android:textSize="9sp"
            android:textStyle="bold" />

        <!-- Progress Preview Container -->
        <LinearLayout
            android:id="@+id/panelPreviewContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">
            <!-- Programmatically filled by ActiveStoryAdapter -->
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
