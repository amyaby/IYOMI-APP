<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/reveal_hdr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        android:paddingTop="36dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvStoryTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="L'Alien au café ✨"
                android:textColor="@color/text_main"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginTop="1dp">

                <TextView
                    android:id="@+id/tvStoryMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4 panels · 4 joueurs"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvTotalStoryReactions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="🔥 12"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:visibility="visible" />
            </LinearLayout>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnShare"
            style="@style/NavBackBtn"
            android:contentDescription="Partager"
            android:src="@drawable/ic_share"
            app:tint="@color/primary" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/reaction_bar"
        app:layout_constraintTop_toBottomOf="@id/reveal_hdr">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPanels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingBottom="10dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_reveal_panel" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Emoji Reaction Bar -->
    <LinearLayout
        android:id="@+id/reaction_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="4dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toTopOf="@+id/exp_bar">

        <TextView
            android:id="@+id/btnReactFunny"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_nav_btn"
            android:gravity="center"
            android:text="😂"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnReactHeart"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/bg_nav_btn"
            android:gravity="center"
            android:text="❤️"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnReactFire"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/bg_nav_btn"
            android:gravity="center"
            android:text="🔥"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnReactClap"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/bg_nav_btn"
            android:gravity="center"
            android:text="👏"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Export Bar -->
    <LinearLayout
        android:id="@+id/exp_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        android:paddingVertical="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnExportPng"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="#F9F5FF"
            android:drawableStart="@drawable/ic_download"
            android:drawablePadding="8dp"
            android:text="PNG"
            android:textAllCaps="false"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            app:cornerRadius="12dp"
            app:strokeColor="@color/border_light"
            app:strokeWidth="1dp" />

        <Button
            android:id="@+id/btnExportPdf"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:backgroundTint="#F9F5FF"
            android:drawableStart="@drawable/ic_pdf"
            android:drawablePadding="8dp"
            android:text="PDF"
            android:textAllCaps="false"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            app:cornerRadius="12dp"
            app:strokeColor="@color/border_light"
            app:strokeWidth="1dp" />

        <Button
            android:id="@+id/btnMyBds"
            style="@style/PrimaryButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1.4"
            android:paddingVertical="10dp"
            android:text="Mes BDs"
            android:textSize="13sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
